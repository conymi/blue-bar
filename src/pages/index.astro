---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MulkkachiHero from '../components/MulkkachiHero.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/galmuri@2.40.3/dist/galmuri.css" />
	</head>
	<body>
		<Header />
		<main>
			<MulkkachiHero />
			<h1>고유한 것을 찾아 이야기로 만듭니다</h1>
			<p>바탕이 되는 정체성을 브랜드와 콘텐츠로 기획하는 물까치입니다.</p>
		</main>
		<Footer />
	</body>
</html>
<style>
	main {
		width: auto;
		max-width: 1400px;
	}
	h1 {
		font-size: clamp(2rem, 6vw, 4rem);
		line-height: 1.3;
		word-break: keep-all;
		text-align: center;
	}
	main > p {
		text-align: center;
		word-break: keep-all;
	}
</style>
