---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';

const posts = [
	{
		title: '도시는 답이 아니라 질문이 될 수 있을까',
		description: '여행하고 싶은 도시와 살아보고 싶은 도시는 왜 다를까.',
		date: '2026. 07. 09',
		category: '질문도시 노트',
		url: '/city-question/city-as-question',
	},
	{
		title: '여행지는 고르지만, 살아볼 도시는 왜 고르기 어려울까',
		description: '도시 선택은 장소가 아니라 삶의 리듬을 고르는 일이다.',
		date: '준비 중',
		category: '질문도시 노트',
		url: '#',
	},
];
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title="도시질문 | mulkkachi" description="도시를 답이 아니라 질문으로 바라보는 물까치의 기록" />
	</head>
	<body>
		<Header />

		<main class="city-question-page">
			<section class="hero">
				<p class="eyebrow">MULKKACHI ARCHIVE</p>
				<h1>도시질문</h1>
				<p class="intro">
					도시는 답이 아니라 질문이 될 수 있을까. 물까치는 지방 이주와 도시 선택을 둘러싼 질문들을 기록합니다.
				</p>
			</section>

			<section class="featured">
				<a href={posts[0].url} class="featured-card">
					<p class="category">{posts[0].category}</p>
					<h2>{posts[0].title}</h2>
					<p>{posts[0].description}</p>
					<span>{posts[0].date}</span>
				</a>
			</section>

			<section class="post-list">
				{posts.map((post) => (
					<a href={post.url} class="post-card">
						<p class="category">{post.category}</p>
						<h3>{post.title}</h3>
						<p>{post.description}</p>
						<span>{post.date}</span>
					</a>
				))}
			</section>
		</main>
	</body>
</html>

<style>
	.city-question-page {
		max-width: 1080px;
		margin: 0 auto;
		padding: 6rem 1.5rem 8rem;
	}

	.hero {
		margin-bottom: 5rem;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-size: 0.9rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		color: #2f46ff;
	}

	h1 {
		margin: 0 0 1.5rem;
		font-size: clamp(4rem, 10vw, 8rem);
		line-height: 1;
		letter-spacing: -0.06em;
	}

	.intro {
		max-width: 720px;
		font-size: 1.25rem;
		line-height: 1.8;
		color: #343a46;
		word-break: keep-all;
	}

	.featured-card {
		display: block;
		padding: 4rem;
		margin-bottom: 2rem;
		background: #f1f4ff;
		border-radius: 32px;
		text-decoration: none;
		color: inherit;
	}

	.featured-card h2 {
		max-width: 820px;
		margin: 0.8rem 0 1.2rem;
		font-size: clamp(2.4rem, 6vw, 5rem);
		line-height: 1.12;
		letter-spacing: -0.05em;
		word-break: keep-all;
	}

	.featured-card p {
		max-width: 680px;
		font-size: 1.15rem;
		line-height: 1.7;
	}

	.category {
		margin: 0;
		font-size: 0.9rem;
		font-weight: 800;
		color: #2f46ff;
		letter-spacing: 0.08em;
	}

	.post-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
		margin-top: 2rem;
	}

	.post-card {
		display: block;
		padding: 2rem;
		border: 1px solid #e5e7eb;
		border-radius: 24px;
		text-decoration: none;
		color: inherit;
		background: #fff;
	}

	.post-card h3 {
		margin: 0.7rem 0;
		font-size: 1.6rem;
		line-height: 1.35;
		letter-spacing: -0.04em;
		word-break: keep-all;
	}

	.post-card p {
		line-height: 1.7;
		color: #4b5563;
		word-break: keep-all;
	}

	.post-card span,
	.featured-card span {
		display: inline-block;
		margin-top: 1rem;
		color: #6b7280;
		font-size: 0.95rem;
	}

	@media (max-width: 720px) {
		.city-question-page {
			padding: 4rem 1.2rem 6rem;
		}

		.featured-card {
			padding: 2rem;
			border-radius: 24px;
		}

		.post-list {
			grid-template-columns: 1fr;
		}
	}
</style>