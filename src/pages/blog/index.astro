---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
			title="웹진 | FluffyOcto"
			description="웹진 fluffyocto는  준비 중입니다."
		/>
	</head>

	<body>
		<Header />

		<main class="webzine-page">
			<section class="webzine-hero">
				<p class="eyebrow">MULKKACHI WEBZINE</p>
				<h1>웹진</h1>
				<p class="intro">
					세상 모든 관심사에 대한 이야기.
				</p>
			</section>

			<section class="coming-soon">
				<img
					src="/images/webzine/octo.png"
					alt="fluffy octo"
					class="fluffy-image"
				/>

				<div class="message">
					<p class="label">fluffy octo</p>
					<h2>웹진은 준비 중입니다.</h2>
					<p>
						곧 찾아올께요!
					</p>
				</div>
			</section>
		</main>

		
		<Footer />
	</body>
</html>

<style>
.intro-section {
	display: grid;
	grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
	gap: 5rem;
	align-items: center;
	max-width: 1120px;
	margin: 8rem auto;
	padding: 6rem 2rem;
}

.intro-copy .eyebrow {
	margin: 0 0 1.5rem;
	font-size: 0.9rem;
	font-weight: 800;
	letter-spacing: 0.14em;
	color: #2f46ff;
}

.intro-copy h2 {
	margin: 0 0 2rem;
	font-size: clamp(3rem, 7vw, 6rem);
	line-height: 1.05;
	letter-spacing: -0.06em;
	color: #111827;
}

.intro-copy p {
	margin: 0 0 1.5rem;
	font-size: 1.15rem;
	line-height: 1.9;
	color: #1f2937;
	word-break: keep-all;
}

.intro-image {
	margin: 0;
}

.intro-image img {
	display: block;
	width: 100%;
	aspect-ratio: 4 / 5;
	object-fit: cover;
	border-radius: 32px;
	box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
}

@media (max-width: 800px) {
	.intro-section {
		grid-template-columns: 1fr;
		gap: 3rem;
		margin: 5rem auto;
		padding: 4rem 1.5rem;
	}

	.intro-image {
		order: -1;
	}

	.intro-copy h2 {
		font-size: 3rem;
	}
}

	.webzine-page {
		max-width: 1120px;
		margin: 0 auto;
		padding: 6rem 1.5rem 8rem;
	}

	.webzine-hero {
		margin-bottom: 4rem;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-size: 0.9rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		color: #2f46ff;
	}

	h1 {
		margin: 0 0 1.5rem;
		font-size: clamp(4rem, 10vw, 8rem);
		line-height: 1;
		letter-spacing: -0.06em;
	}

	.intro {
		max-width: 720px;
		font-size: 1.25rem;
		line-height: 1.8;
		color: #343a46;
		word-break: keep-all;
	}

	.coming-soon {
		display: grid;
		grid-template-columns: minmax(280px, 460px) 1fr;
		gap: 4rem;
		align-items: center;
		padding: 4rem;
		border-radius: 36px;
		background: #f2f4ff;
	}

	.fluffy-image {
		display: block;
		width: 100%;
		border-radius: 28px;
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.message .label {
		margin: 0 0 1rem;
		font-size: 0.95rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		color: #2f46ff;
	}

	.message h2 {
		margin: 0 0 1.2rem;
		font-size: clamp(2.2rem, 5vw, 4rem);
		line-height: 1.15;
		letter-spacing: -0.06em;
		word-break: keep-all;
	}

	.message p {
		font-size: 1.15rem;
		line-height: 1.8;
		color: #4b5563;
		word-break: keep-all;
	}

	@media (max-width: 800px) {
		.webzine-page {
			padding: 4rem 1.2rem 6rem;
		}

		.coming-soon {
			grid-template-columns: 1fr;
			gap: 2rem;
			padding: 2rem;
			border-radius: 28px;
		}
	}
</style>